{
  "name": "testme",
  "version": "0.2.0",
  "description": "AI-powered product tester — dogfood any product and file GitHub issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/seedquan/testme"
  },
  "homepage": "https://github.com/seedquan/testme#readme",
  "bugs": {
    "url": "https://github.com/seedquan/testme/issues"
  },
  "keywords": ["testing", "ai", "claude", "docker", "github", "qa", "automation"],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "Dockerfile.testme",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "bin": {
    "testme": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@octokit/rest": "^21.1.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1",
    "@types/node": "^22.14.1"
  }
}
